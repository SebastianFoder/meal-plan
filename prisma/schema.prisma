// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ScheduleShiftReason {
  SKIP_DAY
  MANUAL_ADJUST
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  recipes       Recipe[]
  scheduledMeals ScheduledMeal[]
  mealHistory    MealHistory[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Recipe {
  id            String          @id @default(cuid())
  userId        String
  parentRecipeId String?
  name          String
  description   String?
  ingredients   String[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentRecipe  Recipe?         @relation("RecipeVariations", fields: [parentRecipeId], references: [id], onDelete: SetNull)
  variations    Recipe[]        @relation("RecipeVariations")
  scheduledMeals  ScheduledMeal[]
  plannedHistory  MealHistory[] @relation("PlannedRecipeHistory")
  actualHistory   MealHistory[] @relation("ActualRecipeHistory")

  @@index([userId, createdAt])
  @@index([userId, parentRecipeId])
  @@unique([userId, name])
  @@unique([id, userId])
  @@map("MealTemplate")
}

model ScheduledMeal {
  id            String              @id @default(cuid())
  userId        String
  recipeId      String              @map("mealTemplateId")
  startDate     DateTime
  durationDays  Int
  orderIndex    Int
  shiftReason   ScheduleShiftReason @default(MANUAL_ADJUST)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe        Recipe              @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  mealHistory   MealHistory[]

  @@index([userId, startDate, orderIndex])
  @@index([recipeId])
  @@unique([id, userId])
}

model MealHistory {
  id                    String        @id @default(cuid())
  userId                String
  date                  DateTime
  plannedScheduledMealId String?
  plannedRecipeId       String?       @map("plannedTemplateId")
  actualRecipeId        String?       @map("actualTemplateId")
  actualMealName        String?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedScheduledMeal  ScheduledMeal? @relation(fields: [plannedScheduledMealId], references: [id], onDelete: SetNull)
  plannedRecipe         Recipe?        @relation("PlannedRecipeHistory", fields: [plannedRecipeId], references: [id], onDelete: SetNull)
  actualRecipe          Recipe?        @relation("ActualRecipeHistory", fields: [actualRecipeId], references: [id], onDelete: SetNull)

  @@unique([userId, date])
  @@index([userId, date])
  @@index([plannedRecipeId])
  @@index([actualRecipeId])
}
